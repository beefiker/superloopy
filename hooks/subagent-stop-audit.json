{
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "^rovyn$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/src/cli.js\" hook subagent-stop-audit",
            "timeout": 5,
            "statusMessage": "(Superloopy) Validating Audit Verdict"
          }
        ]
      }
    ]
  }
}
