{
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "^(?:fronk|zyro|usk|jumbo)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/src/cli.js\" hook subagent-stop",
            "timeout": 5,
            "statusMessage": "(Superloopy) Verifying Evidence Receipt"
          }
        ]
      },
      {
        "matcher": "^nomi$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/src/cli.js\" hook subagent-stop",
            "timeout": 5,
            "statusMessage": "(Superloopy) Navigator (read-only) — no receipt required"
          }
        ]
      }
    ]
  }
}
